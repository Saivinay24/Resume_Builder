# Database
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL, e.g. Neon, Vercel Postgres, Railway):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth (required)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-at-least-32-chars"
# Full URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth (optional – for "Import from GitHub" projects)
# Create at: https://github.com/settings/developers → New OAuth App
# Homepage: your NEXTAUTH_URL, Callback: NEXTAUTH_URL/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""
